# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_SECRET=change-me-to-any-32-char-random-string

# ── Database ─────────────────────────────────────────────────────────────────
# Option A: Neon (free, no install) → https://neon.tech
#   DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/allposty?sslmode=require
#
# Option B: Local Postgres
#   macOS:  brew install postgresql && brew services start postgresql
#   Ubuntu: sudo apt install postgresql && sudo service postgresql start
#   Then:   createdb allposty
DATABASE_URL=postgres://postgres:postgres@localhost:5432/allposty?sslmode=disable

# ── Redis ────────────────────────────────────────────────────────────────────
# Option A: Upstash (free, no install) → https://upstash.com
#   REDIS_URL=rediss://default:TOKEN@HOST:PORT
#
# Option B: Local Redis
#   macOS:  brew install redis && brew services start redis
#   Ubuntu: sudo apt install redis-server && sudo service redis start
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret-also-random
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ── Cloudflare R2 (media storage) ────────────────────────────────────────────
# Create a bucket at https://dash.cloudflare.com → R2
# Then create an API token with Object Read & Write
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=allposty-media
R2_PUBLIC_URL=https://media.yourdomain.com

# ── OpenAI (AI captions) ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Stripe (billing) ─────────────────────────────────────────────────────────
# Use test keys during development: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products + prices in Stripe dashboard, paste the price IDs here
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ── OAuth credentials ────────────────────────────────────────────────────────
# Instagram + Facebook (same Meta app)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Twitter/X
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Google (YouTube)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
